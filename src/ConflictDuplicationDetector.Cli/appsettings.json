{
  "OpenAI": {
    "ApiKey": "env:OPENAI_API_KEY",
    "Provider": "OpenAI",
    "Model": "gpt-5.1",
    "EmbeddingModel": "text-embedding-3-small",
    "AzureEndpoint": null,
    "AzureApiVersion": "2024-02-01",
    "ApiKeyHeader": null
  },
  "VectorStore": {
    "PersistPath": "./data/vectors.json",
    "MaxSearchResults": 10
  },
  "Analysis": {
    "DuplicationThreshold": 0.85,
    "ChunkSize": 512,
    "ChunkOverlap": 50,
    "MaxConcurrentAgents": 3
  }
}
