@using System.Text.Json
@using ConflictDuplicationDetector.Core.Services
@model JobStatusResponse

@if (Model.Status != JobStatus.Completed || Model.Result is null)
{
    return;
}

<h2 class="govuk-heading-l">Result</h2>

@switch (Model.Result)
{
    case IngestionResult ingestion:
        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Documents processed</dt>
                <dd class="govuk-summary-list__value">@ingestion.DocumentsProcessed</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Chunks created</dt>
                <dd class="govuk-summary-list__value">@ingestion.ChunksCreated</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Chunks skipped</dt>
                <dd class="govuk-summary-list__value">@ingestion.ChunksSkipped</dd>
            </div>
        </dl>
        @if (ingestion.Errors.Count > 0)
        {
            <h3 class="govuk-heading-m">Errors</h3>
            <ul class="govuk-list">
                @foreach (var error in ingestion.Errors)
                {
                    <li>@error</li>
                }
            </ul>
        }
        break;

    case ChatResponse chat:
        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Intent</dt>
                <dd class="govuk-summary-list__value">@chat.Intent</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Results referenced</dt>
                <dd class="govuk-summary-list__value">@chat.ResultCount</dd>
            </div>
        </dl>
        <div class="app-card">
            <p class="govuk-body app-pre-wrap">@chat.Message</p>
        </div>
        break;

    case AnalysisResult analysis:
        var totalFindings = analysis.Duplications.Count + analysis.Conflicts.Count + analysis.Inconsistencies.Count;
        var filterId = $"analysis-results-{Model.JobId:N}";

        <dl class="govuk-summary-list">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Documents</dt>
                <dd class="govuk-summary-list__value">@analysis.Metrics.TotalDocuments</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Chunks</dt>
                <dd class="govuk-summary-list__value">@analysis.Metrics.TotalChunks</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Duplications</dt>
                <dd class="govuk-summary-list__value">@analysis.Duplications.Count</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Conflicts</dt>
                <dd class="govuk-summary-list__value">@analysis.Conflicts.Count</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Inconsistencies</dt>
                <dd class="govuk-summary-list__value">@analysis.Inconsistencies.Count</dd>
            </div>
        </dl>

        @if (totalFindings == 0)
        {
            <p class="govuk-body">No analysis findings were returned for this job.</p>
        }
        else
        {
            <div id="@filterId" class="app-analysis-results">
                <div class="app-analysis-filters" aria-label="Filter analysis results">
                    <span class="govuk-label">Show result types</span>
                    <label class="app-analysis-filter">
                        <input type="checkbox" value="Conflict" checked />
                        Conflicts
                    </label>
                    <label class="app-analysis-filter">
                        <input type="checkbox" value="Duplication" checked />
                        Duplications
                    </label>
                    <label class="app-analysis-filter">
                        <input type="checkbox" value="Inconsistency" checked />
                        Inconsistencies
                    </label>
                </div>

                <table class="govuk-table app-analysis-table">
                    <caption class="govuk-visually-hidden">Analysis findings</caption>
                    <thead>
                        <tr>
                            <th scope="col">Finding</th>
                            <th scope="col">Type</th>
                            <th scope="col">Score / severity</th>
                            <th scope="col">Documents</th>
                            <th scope="col">Evidence</th>
                            <th scope="col">Explanation</th>
                            <th scope="col">Recommendation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in analysis.Conflicts)
                        {
                            <tr data-analysis-type="Conflict">
                                <td><span class="govuk-tag govuk-tag--red">Conflict</span></td>
                                <td>@item.Type</td>
                                <td>@item.Severity</td>
                                <td>
                                    <ul class="app-analysis-list">
                                        <li><strong>Source:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(item.Source)</li>
                                        <li><strong>Target:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(item.Target)</li>
                                    </ul>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.SourceStatement) && string.IsNullOrWhiteSpace(item.TargetStatement))
                                    {
                                        <span>-</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.SourceStatement))
                                    {
                                        <p class="app-analysis-evidence"><strong>Source:</strong> @item.SourceStatement</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.TargetStatement))
                                    {
                                        <p class="app-analysis-evidence"><strong>Target:</strong> @item.TargetStatement</p>
                                    }
                                </td>
                                <td>@item.Explanation</td>
                                <td>@AnalysisResultDisplayFormatter.ValueOrDash(item.Resolution)</td>
                            </tr>
                        }

                        @foreach (var item in analysis.Duplications)
                        {
                            <tr data-analysis-type="Duplication">
                                <td><span class="govuk-tag">Duplication</span></td>
                                <td>@item.Type</td>
                                <td>@item.SimilarityScore.ToString("P0")</td>
                                <td>
                                    <ul class="app-analysis-list">
                                        <li><strong>Source:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(item.Source)</li>
                                        <li><strong>Target:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(item.Target)</li>
                                    </ul>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.SourceExcerpt) && string.IsNullOrWhiteSpace(item.TargetExcerpt))
                                    {
                                        <span>-</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.SourceExcerpt))
                                    {
                                        <p class="app-analysis-evidence"><strong>Source:</strong> @item.SourceExcerpt</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.TargetExcerpt))
                                    {
                                        <p class="app-analysis-evidence"><strong>Target:</strong> @item.TargetExcerpt</p>
                                    }
                                </td>
                                <td>@item.Explanation</td>
                                <td>-</td>
                            </tr>
                        }

                        @foreach (var item in analysis.Inconsistencies)
                        {
                            <tr data-analysis-type="Inconsistency">
                                <td><span class="govuk-tag govuk-tag--grey">Inconsistency</span></td>
                                <td>@item.Type</td>
                                <td>-</td>
                                <td>
                                    @if (item.Occurrences.Count > 0)
                                    {
                                        <ul class="app-analysis-list">
                                            <li><strong>Source:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(item.Occurrences[0])</li>
                                            @if (item.Occurrences.Count > 1)
                                            {
                                                @foreach (var occurrence in item.Occurrences.Skip(1))
                                                {
                                                    <li><strong>Target:</strong> @AnalysisResultDisplayFormatter.FormatDocumentReference(occurrence)</li>
                                                }
                                            }
                                            else
                                            {
                                                <li><strong>Target:</strong> -</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Variants.Count > 0)
                                    {
                                        <p class="app-analysis-evidence"><strong>Variants:</strong> @string.Join(", ", item.Variants)</p>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@item.Explanation</td>
                                <td>@AnalysisResultDisplayFormatter.ValueOrDash(item.SuggestedStandard)</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <p class="govuk-body app-analysis-no-results" hidden>No analysis findings match the selected filters.</p>
            </div>

            <script>
                (() => {
                    const container = document.getElementById('@filterId');
                    if (!container) {
                        return;
                    }

                    const filters = Array.from(container.querySelectorAll('.app-analysis-filter input[type="checkbox"]'));
                    const rows = Array.from(container.querySelectorAll('tbody tr[data-analysis-type]'));
                    const noResults = container.querySelector('.app-analysis-no-results');

                    const applyFilters = () => {
                        const selectedTypes = new Set(filters.filter(filter => filter.checked).map(filter => filter.value));
                        let visibleRows = 0;

                        rows.forEach(row => {
                            const isVisible = selectedTypes.has(row.dataset.analysisType);
                            row.hidden = !isVisible;
                            if (isVisible) {
                                visibleRows += 1;
                            }
                        });

                        if (noResults) {
                            noResults.hidden = visibleRows > 0;
                        }
                    };

                    filters.forEach(filter => filter.addEventListener('change', applyFilters));
                    applyFilters();
                })();
            </script>
        }
        break;

    default:
        <pre class="app-card app-pre-wrap">@JsonSerializer.Serialize(Model.Result, new JsonSerializerOptions { WriteIndented = true })</pre>
        break;
}

