@page
@model AnalyseModel
@{
    ViewData["Title"] = "Analyse knowledge base";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Analyse the knowledge base</h1>
        <p class="govuk-body">Run an analysis across all documents that have already been uploaded and ingested.</p>

        <partial name="_ValidationSummary" />

        <form method="post">
            <div class="govuk-form-group">
                <label class="govuk-label" asp-for="Type">Type of analysis</label>
                <select class="govuk-select" asp-for="Type">
                    <option value="all">All checks</option>
                    <option value="duplications">Duplications</option>
                    <option value="conflicts">Conflicts</option>
                    <option value="inconsistencies">Inconsistencies</option>
                </select>
            </div>

            <div class="govuk-form-group">
                <label class="govuk-label" asp-for="Topic">Topic or area to focus on</label>
                <span class="govuk-hint">Optional. This is most useful for conflicts or inconsistencies.</span>
                <input class="govuk-input" asp-for="Topic" />
            </div>

            <button class="govuk-button" type="submit">Start analysis</button>
        </form>
    </div>
</div>
