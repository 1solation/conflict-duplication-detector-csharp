@page
@model CheckModel
@{
    ViewData["Title"] = "Check a document";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Check a document</h1>
        <p class="govuk-body">Upload a single document to compare it with the knowledge base. The document will not be added to the knowledge base.</p>

        <partial name="_ValidationSummary" />

        <form method="post" enctype="multipart/form-data">
            <div class="govuk-form-group">
                <label class="govuk-label" asp-for="UploadFile">Document</label>
                <span class="govuk-hint">Supported formats are PDF, Word, HTML and plain text.</span>
                <span class="govuk-error-message" asp-validation-for="UploadFile"></span>
                <input class="govuk-file-upload" asp-for="UploadFile" type="file" />
            </div>

            <div class="govuk-form-group">
                <label class="govuk-label" asp-for="Type">What to check</label>
                <select class="govuk-select" asp-for="Type">
                    <option value="all">All checks</option>
                    <option value="duplications">Duplications</option>
                    <option value="conflicts">Conflicts</option>
                    <option value="inconsistencies">Inconsistencies</option>
                </select>
            </div>

            <button class="govuk-button" type="submit">Check document</button>
        </form>
    </div>
</div>
