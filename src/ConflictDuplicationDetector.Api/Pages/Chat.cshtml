@page
@model ChatModel
@{
    ViewData["Title"] = "Ask a question";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">Ask a question</h1>
        <p class="govuk-body">Ask a question about the uploaded documents. The service will route your question to the most relevant analysis mode.</p>

        <partial name="_ValidationSummary" />

        <form method="post">
            <div class="govuk-form-group">
                <label class="govuk-label" asp-for="Message">Question</label>
                <span class="govuk-hint">For example, ask whether two documents contradict each other or where a topic is duplicated.</span>
                <span class="govuk-error-message" asp-validation-for="Message"></span>
                <textarea class="govuk-textarea" asp-for="Message"></textarea>
            </div>

            <button class="govuk-button" type="submit">Ask question</button>
        </form>
    </div>
</div>
