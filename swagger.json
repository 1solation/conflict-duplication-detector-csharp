{
    "openapi": "3.0.1",
    "info": {
        "title": "Conflict & Duplication Detector API",
        "description": "HTTP API for document ingestion, knowledge-base analysis, file checks, and chat.\n\nLong-running operations (ingest, analyse, check, chat) return **202 Accepted** with a job ID.\nPoll **GET /api/jobs/{jobId}** until status is `completed` or `failed`.",
        "version": "v1"
    },
    "paths": {
        "/api/health": {
            "get": {
                "tags": [
                    "Detector"
                ],
                "summary": "Health check",
                "description": "Returns API health and knowledge-base summary.",
                "operationId": "GetHealth",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HealthResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "status": "healthy",
                                    "openAiConfigured": true,
                                    "knowledgeBaseExists": true,
                                    "chunkCount": 142
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/knowledge-base": {
            "get": {
                "tags": [
                    "Detector"
                ],
                "summary": "Knowledge base status",
                "description": "Returns whether the vector store exists and how many chunks are loaded.",
                "operationId": "GetKnowledgeBase",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/KnowledgeBaseStatusResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "exists": true,
                                    "chunkCount": 142,
                                    "persistPath": "./data/vectors.json"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/documents": {
            "post": {
                "tags": [
                    "Detector"
                ],
                "summary": "Ingest documents",
                "description": "Upload one or more documents and enqueue ingestion into the knowledge base. Returns 202 with a job ID.\n\n**Supported file formats:**\n- PDF (.pdf) - `application/pdf`\n- Word (.docx) - `application/vnd.openxmlformats-officedocument.wordprocessingml.document`\n- HTML (.html, .htm) - `text/html`\n- Plain text (.txt) - `text/plain`",
                "operationId": "IngestDocuments",
                "requestBody": {
                    "description": "One or more document files to upload. Supported formats: PDF, DOCX, HTML, TXT",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "files"
                                ],
                                "type": "object",
                                "properties": {
                                    "files": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        },
                                        "description": "Document files (PDF, DOCX, HTML, or TXT)"
                                    }
                                }
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JobAcceptedResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                    "type": "Ingest",
                                    "status": "Pending",
                                    "statusUrl": "/api/jobs/3fa85f64-5717-4562-b3fc-2c963f66afa6"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/analysis": {
            "post": {
                "tags": [
                    "Detector"
                ],
                "summary": "Analyse the knowledge base",
                "description": "Enqueue analysis of all ingested documents (duplications, conflicts, inconsistencies). Returns 202 with a job ID. Type can be 'all', 'duplications', 'conflicts', or 'inconsistencies'.",
                "operationId": "StartAnalysis",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AnalysisJobRequest"
                            },
                            "example": {
                                "type": "all",
                                "topic": null
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JobAcceptedResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                    "type": "Analysis",
                                    "status": "Pending",
                                    "statusUrl": "/api/jobs/3fa85f64-5717-4562-b3fc-2c963f66afa6"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/check": {
            "post": {
                "tags": [
                    "Detector"
                ],
                "summary": "Check a file against the knowledge base",
                "description": "Upload a file and compare it against the ingested knowledge base without adding it. Returns 202 with a job ID.\n\n**Supported file formats:**\n- PDF (.pdf) - `application/pdf`\n- Word (.docx) - `application/vnd.openxmlformats-officedocument.wordprocessingml.document`\n- HTML (.html, .htm) - `text/html`\n- Plain text (.txt) - `text/plain`\n\n**Query parameters:**\n- `type` (optional): 'all', 'duplications', 'conflicts', or 'inconsistencies' (default: 'all')",
                "operationId": "CheckDocument",
                "parameters": [
                    {
                        "name": "type",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "description": "Document file to upload. Supported formats: PDF, DOCX, HTML, TXT",
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "file"
                                ],
                                "type": "object",
                                "properties": {
                                    "file": {
                                        "type": "string",
                                        "description": "The document file (PDF, DOCX, HTML, or TXT)",
                                        "format": "binary"
                                    }
                                }
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JobAcceptedResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                    "type": "Check",
                                    "status": "Pending",
                                    "statusUrl": "/api/jobs/3fa85f64-5717-4562-b3fc-2c963f66afa6"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/chat": {
            "post": {
                "tags": [
                    "Detector"
                ],
                "summary": "Chat with the knowledge base - streaming not supported by DfE AI API yet",
                "description": "Enqueue a natural-language query against ingested documents. Returns 202 with a job ID. The system auto-routes queries: use words like 'duplicate/copy' for duplication analysis, 'conflict/contradict' for conflict analysis, 'terminology/format' for inconsistency analysis.",
                "operationId": "StartChat",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ChatJobRequest"
                            },
                            "example": {
                                "message": "Find any duplicates related to the refund policy"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JobAcceptedResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                    "type": "Chat",
                                    "status": "Pending",
                                    "statusUrl": "/api/jobs/3fa85f64-5717-4562-b3fc-2c963f66afa6"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/jobs": {
            "get": {
                "tags": [
                    "Detector"
                ],
                "summary": "List recent jobs",
                "description": "Returns a list of recent jobs ordered by creation time. Optional query param 'limit' controls the number of jobs returned (default 50).",
                "operationId": "ListJobs",
                "parameters": [
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/JobStatusResponse"
                                    }
                                },
                                "example": [
                                    {
                                        "provider": "Azure OpenAI",
                                        "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                        "type": "Analysis",
                                        "status": "Completed",
                                        "createdAt": "2026-06-05T14:30:00Z",
                                        "startedAt": "2026-06-05T14:30:01Z",
                                        "completedAt": "2026-06-05T14:30:15Z",
                                        "error": null,
                                        "result": null
                                    },
                                    {
                                        "provider": "Azure OpenAI",
                                        "jobId": "7ca85f64-5717-4562-b3fc-2c963f66afa7",
                                        "type": "Ingest",
                                        "status": "Running",
                                        "createdAt": "2026-06-05T14:32:00Z",
                                        "startedAt": "2026-06-05T14:32:01Z",
                                        "completedAt": null,
                                        "error": null,
                                        "result": null
                                    }
                                ]
                            }
                        }
                    }
                }
            }
        },
        "/api/jobs/{jobId}": {
            "get": {
                "tags": [
                    "Detector"
                ],
                "summary": "Get job status and result",
                "description": "Poll this endpoint until status is 'Completed' or 'Failed'. The 'result' field contains the analysis output when complete.",
                "operationId": "GetJob",
                "parameters": [
                    {
                        "name": "jobId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JobStatusResponse"
                                },
                                "example": {
                                    "provider": "Azure OpenAI",
                                    "jobId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                                    "type": "Analysis",
                                    "status": "Completed",
                                    "createdAt": "2026-06-05T14:30:00Z",
                                    "startedAt": "2026-06-05T14:30:01Z",
                                    "completedAt": "2026-06-05T14:30:15Z",
                                    "error": null,
                                    "result": {
                                        "duplications": [
                                            {
                                                "type": "Semantic",
