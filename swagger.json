        }
    },
    "components": {
        "schemas": {
            "AnalysisJobRequest": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "nullable": true
                    },
                    "topic": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false,
                "description": "Request body for knowledge-base analysis."
            },
            "ChatJobRequest": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false,
                "description": "Request body for chat against the knowledge base."
            },
            "HealthResponse": {
                "type": "object",
                "properties": {
                    "provider": {
                        "type": "string",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "nullable": true
                    },
                    "openAiConfigured": {
                        "type": "boolean"
                    },
                    "knowledgeBaseExists": {
                        "type": "boolean"
                    },
                    "chunkCount": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "additionalProperties": false,
                "description": "API health check response."
            },
            "HttpValidationProblemDetails": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "nullable": true
                    },
                    "title": {
                        "type": "string",
                        "nullable": true
                    },
                    "status": {
                        "type": "integer",
                        "format": "int32",
                        "nullable": true
                    },
                    "detail": {
                        "type": "string",
                        "nullable": true
                    },
                    "instance": {
                        "type": "string",
                        "nullable": true
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "nullable": true
                    }
                },
                "additionalProperties": {}
            },
            "JobAcceptedResponse": {
                "type": "object",
                "properties": {
                    "provider": {
                        "type": "string",
                        "nullable": true
                    },
                    "jobId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "type": {
                        "$ref": "#/components/schemas/JobType"
                    },
                    "status": {
                        "$ref": "#/components/schemas/JobStatus"
                    },
                    "statusUrl": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false,
                "description": "Summary returned when a job is accepted."
            },
            "JobStatus": {
                "enum": [
                    0,
                    1,
                    2,
                    3
                ],
                "type": "integer",
                "description": "Status of a background job.",
                "format": "int32"
            },
            "JobStatusResponse": {
                "type": "object",
                "properties": {
                    "provider": {
                        "type": "string",
                        "nullable": true
                    },
                    "jobId": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "type": {
                        "$ref": "#/components/schemas/JobType"
                    },
                    "status": {
                        "$ref": "#/components/schemas/JobStatus"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "startedAt": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "completedAt": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "error": {
                        "type": "string",
                        "nullable": true
                    },
                    "result": {
                        "nullable": true
                    }
                },
                "additionalProperties": false,
                "description": "Full job state including result when complete."
            },
            "JobType": {
                "enum": [
                    0,
                    1,
                    2,
                    3
                ],
                "type": "integer",
                "description": "Type of background operation.",
                "format": "int32"
            },
            "KnowledgeBaseStatusResponse": {
                "type": "object",
                "properties": {
                    "provider": {
                        "type": "string",
                        "nullable": true
                    },
                    "exists": {
                        "type": "boolean"
                    },
                    "chunkCount": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "persistPath": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false,
                "description": "Knowledge base status."
            }
        },
        "securitySchemes": {
            "ApiKey": {
                "type": "apiKey",
                "description": "API key passed in the X-Api-Key header.",
                "name": "X-Api-Key",
                "in": "header"
            }
        }
    },
    "security": [
        {
            "ApiKey": []
        }
    ]
}
