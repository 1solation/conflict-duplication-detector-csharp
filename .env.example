# Copy to .env and fill in values: cp .env.example .env
# Docker Compose loads .env automatically from the project root.

# Required: OpenAI or Azure OpenAI API key
OPENAI_API_KEY=

# Required for inbound API auth (X-Api-Key header). Leave empty to disable auth.
Auth__ApiKey=

# --- Azure OpenAI (uncomment and set when not using public OpenAI) ---
# OpenAI__Provider=AzureOpenAI
# OpenAI__AzureEndpoint=https://your-resource.openai.azure.com/
# OpenAI__AzureApiVersion=2024-10-21
# OpenAI__ApiKeyHeader=api-key
# OpenAI__Model=gpt-4.1-mini
# OpenAI__EmbeddingModel=text-embedding-3-large
